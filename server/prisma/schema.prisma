generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  WORKSPACE_OWNER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AIStaffStatus {
  ACTIVE
  INACTIVE
  TRAINING
}

enum AIStaffPersonality {
  PROFESSIONAL
  FRIENDLY
  ANALYTICAL
  CREATIVE
  DIRECT
}

enum WorkflowTriggerType {
  MANUAL
  SCHEDULED
  EVENT
}

enum TaskApprovalStatus {
  NONE
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MessageSenderType {
  USER
  AI_STAFF
}

enum IntegrationType {
  EMAIL
  WEBHOOK
  SMARTPROMPTIQ_API
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum AuditActorType {
  USER
  AI_STAFF
  SYSTEM
}

enum DelegationStatus {
  PLANNING
  EXECUTING
  REVIEWING
  PENDING_APPROVAL
  COMPLETED
  FAILED
}

enum SubtaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(MEMBER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownedWorkspaces Workspace[]
  memberships     WorkspaceMember[]
  messageThreads  MessageThread[]
  delegations     Delegation[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  industry  String?
  brandVoice String?
  logoUrl   String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner            User               @relation(fields: [ownerId], references: [id])
  members          WorkspaceMember[]
  aiStaff          AIStaff[]
  toolIntegrations ToolIntegration[]
  workflows        Workflow[]
  tasks            Task[]
  messageThreads   MessageThread[]
  documents        Document[]
  subscription     Subscription?
  auditLogs        AuditLog[]
  apiKeys          APIKey[]
  usageLogs        UsageLog[]
  delegations      Delegation[]
  knowledgeEntries KnowledgeEntry[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        UserRole @default(MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model AIStaff {
  id             String             @id @default(uuid())
  workspaceId    String
  name           String
  title          String?
  roleType       String
  description    String?
  personality    AIStaffPersonality @default(PROFESSIONAL)
  tone           String?
  systemPrompt   String?
  avatarImageUrl String?
  avatarConfig   Json               @default("{}")
  modelProvider  String             @default("openai")
  modelName      String             @default("gpt-4")
  temperature    Float              @default(0.7)
  maxTokens      Int                @default(2048)
  modelConfig    Json               @default("{}")
  tools          Json               @default("[]")
  isManager      Boolean            @default(false)
  status         AIStaffStatus      @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows           Workflow[]
  tasks               Task[]
  messageThreads      MessageThread[]
  managedDelegations  Delegation[]         @relation("ManagedDelegations")
  assignedSubtasks    DelegationSubtask[]  @relation("AssignedSubtasks")
}

model AIStaffRoleTemplate {
  id                  String @id @default(uuid())
  name                String
  description         String
  category            String @default("general")
  icon                String @default("user")
  defaultPersonality  AIStaffPersonality @default(PROFESSIONAL)
  defaultTone         String @default("professional and helpful")
  defaultSystemPrompt String @default("")
  defaultPrompts      Json   @default("[]")
  defaultTools        Json   @default("[]")
  defaultWorkflows    Json   @default("[]")
  avatarPrompt        String @default("")
  defaultAvatarConfig Json   @default("{}")
}

model ToolIntegration {
  id          String            @id @default(uuid())
  workspaceId String
  type        IntegrationType
  credentials Json              @default("{}")
  status      IntegrationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Workflow {
  id           String              @id @default(uuid())
  workspaceId  String
  aiStaffId    String?
  name         String
  triggerType  WorkflowTriggerType @default(MANUAL)
  scheduleCron String?
  stepsJson    Json                @default("[]")
  status       WorkflowStatus      @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiStaff   AIStaff?  @relation(fields: [aiStaffId], references: [id], onDelete: SetNull)
  tasks     Task[]
}

model Task {
  id              String             @id @default(uuid())
  workspaceId     String
  aiStaffId       String?
  workflowId      String?
  status          TaskStatus         @default(PENDING)
  approvalStatus  TaskApprovalStatus @default(NONE)
  approvalNote    String?
  inputPayload    Json               @default("{}")
  outputPayload   Json               @default("{}")
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime           @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiStaff   AIStaff?  @relation(fields: [aiStaffId], references: [id], onDelete: SetNull)
  workflow  Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
}

model MessageThread {
  id              String   @id @default(uuid())
  workspaceId     String
  aiStaffId       String?
  createdByUserId String
  title           String
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiStaff   AIStaff?  @relation(fields: [aiStaffId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdByUserId], references: [id])
  messages  Message[]
}

model Message {
  id          String            @id @default(uuid())
  threadId    String
  senderType  MessageSenderType
  content     String
  attachments Json              @default("[]")
  createdAt   DateTime          @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Document {
  id          String   @id @default(uuid())
  workspaceId String
  title       String
  type        String
  storageUrl  String
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model BillingPlan {
  id            String        @id @default(uuid())
  name          String
  priceMonthly  Decimal
  priceYearly   Decimal
  maxAiStaff    Int
  maxWorkspaces Int
  featuresJson  Json          @default("{}")

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(uuid())
  workspaceId          String             @unique
  planId               String
  status               SubscriptionStatus @default(TRIALING)
  renewsAt             DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      BillingPlan @relation(fields: [planId], references: [id])
}

model AuditLog {
  id          String         @id @default(uuid())
  workspaceId String
  actorType   AuditActorType
  actorId     String
  action      String
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id               String   @id @default(uuid())
  workspaceId      String
  aiStaffId        String?
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  costUsd          Float    @default(0)
  durationMs       Int      @default(0)
  endpoint         String   @default("chat")
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model APIKey {
  id         String    @id @default(uuid())
  workspaceId String
  keyHash    String
  label      String
  scopes     Json      @default("[]")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Delegation System ────────────────────────────────────────────────────────

model Delegation {
  id              String           @id @default(uuid())
  workspaceId     String
  managerId       String
  createdByUserId String
  goal            String
  context         String?
  plan            Json             @default("[]")
  finalOutput     String?
  status          DelegationStatus @default(PLANNING)
  requireApproval Boolean          @default(false)
  approvalNote    String?
  isRecurring     Boolean          @default(false)
  scheduleCron    String?
  lastRunAt       DateTime?
  runCount        Int              @default(0)
  totalTokensUsed Int              @default(0)
  totalCostUsd    Float            @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  manager   AIStaff            @relation("ManagedDelegations", fields: [managerId], references: [id], onDelete: Cascade)
  createdBy User               @relation(fields: [createdByUserId], references: [id])
  subtasks  DelegationSubtask[]
  history   DelegationHistory[]
  messages  DelegationMessage[]
}

model DelegationSubtask {
  id           String        @id @default(uuid())
  delegationId String
  assigneeId   String?
  orderIndex   Int           @default(0)
  title        String
  instructions String
  dependsOn    Json          @default("[]")
  output       String?
  status       SubtaskStatus @default(PENDING)
  tokensUsed   Int           @default(0)
  costUsd      Float         @default(0)
  durationMs   Int           @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime      @default(now())

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  assignee   AIStaff?   @relation("AssignedSubtasks", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model KnowledgeEntry {
  id          String   @id @default(uuid())
  workspaceId String
  title       String
  content     String
  category    String   @default("general")
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model DelegationMessage {
  id           String   @id @default(uuid())
  delegationId String
  senderId     String?
  senderName   String
  senderRole   String
  content      String
  phase        String   @default("execution")
  createdAt    DateTime @default(now())

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
}

model DelegationHistory {
  id              String   @id @default(uuid())
  delegationId    String
  runNumber       Int
  status          String
  finalOutput     String?
  totalTokensUsed Int      @default(0)
  totalCostUsd    Float    @default(0)
  durationMs      Int      @default(0)
  subtaskSummary  Json     @default("[]")
  createdAt       DateTime @default(now())

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
}
