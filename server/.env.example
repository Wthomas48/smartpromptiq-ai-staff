# PostgreSQL Database
DATABASE_URL="postgresql://user:password@localhost:5432/smartpromptiq_ai_staff"

# JWT Secrets (generate secure random strings for production)
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5180

# AI Providers (add your keys)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Default AI model
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini

# Stripe (for billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Redis (for BullMQ task queue)
REDIS_URL="redis://localhost:6379"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
