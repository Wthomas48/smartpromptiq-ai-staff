# ===========================================
# SmartPromptIQ AI Staff - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# PostgreSQL Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/smartpromptiq_ai_staff"

# JWT Secrets (change these in production!)
JWT_SECRET="smartpromptiq-secret-key-change-in-production"
JWT_REFRESH_SECRET="smartpromptiq-refresh-secret-key-change-in-production"

# Server
PORT=3001
NODE_ENV=development

# Client (Vite dev server)
CLIENT_PORT=5173

# Stripe (placeholder - not wired yet)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI / LLM Integration (placeholder - not wired yet)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
